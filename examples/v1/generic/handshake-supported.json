{
  "schemaVersion": "adapter_manifest.v1-alpha.1",
  "adapter": {
    "id": "example.adapter.local",
    "name": "Example Local Adapter",
    "version": "0.1.0-alpha.1"
  },
  "runtime": {
    "id": "example.runtime.local",
    "name": "Example Local Runtime",
    "version": "0.1.0"
  },
  "supportedProtocolVersions": [
    "1.0.0-alpha.1"
  ],
  "supportedCapabilities": [
    {
      "capabilityId": "execution.submit",
