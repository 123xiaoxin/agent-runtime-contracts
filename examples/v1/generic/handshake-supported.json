    {
      "capabilityId": "evidence.observed",
      "description": "Expose Runtime-observed execution evidence."
    }
  ],
  "unsupportedCapabilities": [],
  "limits": [
    {
      "limitId": "execution.concurrent.max",
      "value": 1,
      "unit": "execution"
    },
    {
      "limitId": "request.payload.max",
      "value": 262144,
      "unit": "byte"
    }
  ],
  "profileName": "generic-minimal",
  "profileVersion": "0.1.0-alpha.1"
}
