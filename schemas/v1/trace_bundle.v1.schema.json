{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./trace_bundle.v1.schema.json",
  "title": "Trace Bundle v1-alpha.2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "traceId",
    "runtimeId",
    "contractEnvelope",
    "events",
    "result",
    "createdAt"
  ],
  "properties": {
    "schemaVersion": {
      "const": "trace_bundle.v1-alpha.2"
    },
    "requestId": {
      "$ref": "./common_defs.v1.schema.json#/$defs/id"
    },
    "traceId": {
      "$ref": "./common_defs.v1.schema.json#/$defs/traceId"
    },
    "runtimeId": {
      "$ref": "./common_defs.v1.schema.json#/$defs/runtimeId"
    },
    "contractEnvelope": {
      "$ref": "./execution_request.v1.schema.json#/properties/contractEnvelope"
    },
    "events": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "./runtime_event.v1.schema.json"
      }
    },
    "result": {
      "$ref": "./execution_result.v1.schema.json"
    },
    "createdAt": {
      "$ref": "./common_defs.v1.schema.json#/$defs/timestamp"
    }
  }
}
