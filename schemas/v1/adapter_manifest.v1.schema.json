{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./adapter_manifest.v1.schema.json",
  "title": "Adapter Manifest v1-alpha.1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "adapter",
    "runtime",
    "supportedProtocolVersions",
    "supportedCapabilities",
    "unsupportedCapabilities",
    "limits",
    "profileName",
    "profileVersion"
  ],
  "properties": {
    "schemaVersion": {
      "const": "adapter_manifest.v1-alpha.1"
    },
    "adapter": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "version"
      ],
      "properties": {
        "id": {
          "$ref": "./common_defs.v1.schema.json#/$defs/id"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name"
      ],
      "properties": {
        "id": {
          "$ref": "./common_defs.v1.schema.json#/$defs/runtimeId"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "supportedProtocolVersions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[1-9][0-9]*\\.[0-9]+\\.[0-9]+(?:-alpha\\.[1-9][0-9]*)?$"
      }
    },
    "supportedCapabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capabilityId"
        ],
        "properties": {
          "capabilityId": {
            "$ref": "./common_defs.v1.schema.json#/$defs/capabilityId"
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "unsupportedCapabilities": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "capabilityId",
          "reason"
        ],
        "properties": {
          "capabilityId": {
            "$ref": "./common_defs.v1.schema.json#/$defs/capabilityId"
          },
          "reason": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "limits": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "limitId",
          "value"
        ],
        "properties": {
          "limitId": {
            "$ref": "./common_defs.v1.schema.json#/$defs/capabilityId"
          },
          "value": {
            "type": [
              "string",
              "number",
              "boolean"
            ]
          },
          "unit": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "profileName": {
      "type": "string",
      "minLength": 1
    },
    "profileVersion": {
      "type": "string",
      "minLength": 1
    }
  }
}
