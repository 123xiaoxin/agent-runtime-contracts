{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "./common_defs.v1.schema.json",
  "title": "Agent Runtime Contracts Common Definitions v1-alpha.1",
  "$defs": {
    "schemaVersion": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*\\.v[1-9][0-9]*(?:-alpha\\.[1-9][0-9]*)?$"
    },
    "id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]*$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "traceId": {
      "$ref": "#/$defs/id"
    },
    "runtimeId": {
      "$ref": "#/$defs/id"
    },
    "capabilityId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z][a-z0-9]*(?:\\.[a-z0-9]+)*$"
    },
    "digest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "algorithm",
        "value"
      ],
      "properties": {
        "algorithm": {
          "const": "sha256"
        },
        "value": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "artifactRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "uri"
      ],
      "properties": {
        "uri": {
          "type": "string",
          "format": "uri-reference"
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "mediaType": {
          "type": "string",
          "minLength": 1
        },
        "digest": {
          "$ref": "#/$defs/digest"
        }
      }
    }
  }
}
